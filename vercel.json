{
  "redirects": [
    {
      "source": "/ig",
      "destination": "/pages/free-portal.html?utm_source=instagram&utm_medium=social&utm_campaign=bio-link-pinned",
      "permanent": false
    },
    {
      "source": "/pages/course-library.html",
      "destination": "/pages/course-library-v2.html",
      "permanent": false
    },
    {
      "source": "/pages/master-practice.html",
      "destination": "/pages/course-library-v2.html",
      "permanent": false
    },
    {
      "source": "/pages/master-practice",
      "destination": "/pages/course-library-v2.html",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "therapist-home.com" }],
      "destination": "https://www.therapist-home.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/supabase/:path*", "destination": "/404.html" },
    { "source": "/sql/:path*", "destination": "/404.html" },
    { "source": "/docs/specs/:path*", "destination": "/404.html" },
    { "source": "/docs/scripts/:path*", "destination": "/404.html" },
    { "source": "/flutterflow-api/:path*", "destination": "/404.html" },
    { "source": "/.claude/:path*", "destination": "/404.html" },
    { "source": "/system_architecture.txt", "destination": "/404.html" },
    { "source": "/CLAUDE.md", "destination": "/404.html" },
    { "source": "/DOCUMENTATION.md", "destination": "/404.html" },
    { "source": "/docs/master-course/:path*", "destination": "/404.html" },
    { "source": "/docs/meeting-:slug(.*)", "destination": "/404.html" },
    { "source": "/content-leverage/:path*", "destination": "/404.html" },
    { "source": "/docs/nano-banana-prompts.txt", "destination": "/404.html" },
    { "source": "/docs/questionnaire-therapist-recruitment.txt", "destination": "/404.html" },
    { "source": "/docs/sales-rep-guide.html", "destination": "/404.html" },
    { "source": "/docs/sales-rep-guide.pdf", "destination": "/404.html" },
    { "source": "/docs/ux-audit-report.html", "destination": "/404.html" },
    { "source": "/docs/ux-audit-report.pdf", "destination": "/404.html" },
    { "source": "/docs/design-system/:path*", "destination": "/404.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
